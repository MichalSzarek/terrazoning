# TerraZoning backend — environment variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ---- Database (matches docker-compose.yml defaults) ----
# Optional override for Cloud SQL / managed Postgres.
# If DATABASE_URL is set, it takes precedence over DB_HOST/PORT/NAME/USER/PASSWORD.
# Examples:
#   DATABASE_URL=postgresql://admin:secret@127.0.0.1:6543/terrazoning
#   DATABASE_URL=postgresql://admin:secret@10.71.0.3:5432/terrazoning
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=terrazoning
DB_USER=terrazoning
DB_PASSWORD=terrazoning

# ---- Application ----
DEBUG=false
LOG_LEVEL=INFO
FUTURE_BUILDABILITY_ENABLED=true

# ---- GCS (Evidence Chain storage) ----
GCS_BUCKET=terrazoning-evidence-dev
GCS_PROJECT=terrazoning-dev

# ---- External APIs ----
ULDK_BASE_URL=https://uldk.gugik.gov.pl

# ---- LLM fallback extractor (Vertex AI / Gemini) ----
# ADC is preferred locally: `gcloud auth application-default login`
# Leave GCP_PROJECT_ID empty to auto-detect the active ADC project.
GCP_PROJECT_ID=
GCP_LOCATION=global
VERTEX_MODEL=gemini-2.5-flash
LLM_FALLBACK_ENABLED=true
LLM_TIMEOUT_S=20
LLM_MAX_OUTPUT_TOKENS=256
LLM_TEMPERATURE=0.0
