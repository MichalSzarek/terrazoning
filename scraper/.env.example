# Scraper env vars — matches backend/.env.example
# The scraper reuses backend's pydantic-settings (terrazoning-backend editable install)

DB_HOST=localhost
DB_PORT=5432
DB_NAME=terrazoning
DB_USER=terrazoning
DB_PASSWORD=terrazoning
DEBUG=false
LOG_LEVEL=INFO

# Vertex AI / Gemini fallback extractor.
# The scraper inherits backend settings via the editable terrazoning-backend package.
GCP_PROJECT_ID=
GCP_LOCATION=global
VERTEX_MODEL=gemini-2.5-flash
LLM_FALLBACK_ENABLED=true
LLM_TIMEOUT_S=20
LLM_MAX_OUTPUT_TOKENS=256
LLM_TEMPERATURE=0.0
